# Bronx Bot Dashboard Environment Configuration
# Copy this file to .env and configure your settings

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=bronxbot

# Redis Configuration (required for production session storage)
# Either use REDIS_URL (Render format) OR individual host/port/password
# REDIS_URL takes precedence if both are set
REDIS_URL=redis://localhost:6379
# OR use individual parameters:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Server Configuration  
PORT=3000
NODE_ENV=production

# Discord Bot Integration
DISCORD_TOKEN=your_bot_token
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/callback

# Optional: Security Settings
SESSION_SECRET=your_random_session_secret
ADMIN_PASSWORD=your_admin_password

# Optional: Logging
LOG_LEVEL=info
LOG_FILE=dashboard.log