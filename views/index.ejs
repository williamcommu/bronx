<!DOCTYPE html>
<html lang="en">

<%- include('partials/head', { title: "bronx | discord economy, gambling & mining bot", custom_css: ['/css/style.css', '/css/consent.css', '/css/update-banner.css', '/css/preview-banner.css'] }) %>
<body>
    <%- include('partials/navbar', { pageName: 'home' }) %>

    <!-- Hero Section -->
    <section class="hero">
        <!-- Particle canvas -->
        <canvas id="particleCanvas" class="particle-canvas"></canvas>
        <!-- Parallax background layers -->
        <%- include('partials/ambient_bg') %>
        <div class="container">
            <div class="hero-content">
                <h1 class="logo">bronx</h1>
                <p class="tagline" id="tagline"></p>
                <div class="cta-group">
                    <a href="#" class="btn btn-primary" id="invite-btn">invite bronx</a>
                    <a href="https://dashboard.bronxbot.xyz" class="btn btn-secondary" id="login-btn">dashboard</a>
                </div>
            </div>
        </div>
        <div class="scroll-indicator" id="scrollIndicator">
            <i class="fas fa-chevron-down"></i>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features" id="features">
        <div class="container">
            <h2 class="section-title" data-reveal="up">features</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-coins"></i></div>
                    <h3 class="feature-title">economy</h3>
                    <p class="feature-desc">balance, banking, daily rewards, work, prestige, rebirth, pets, skill trees,
                        crafting, mastery.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-dice"></i></div>
                    <h3 class="feature-title">gambling</h3>
                    <p class="feature-desc">blackjack, slots, coinflip, dice, roulette, frogger, crash, poker, bomb,
                        lottery.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-fish"></i></div>
                    <h3 class="feature-title">fishing</h3>
                    <p class="feature-desc">catch fish, crews, autofisher, fishdex collection, lockfish, mastery
                        bonuses.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-mountain"></i></div>
                    <h3 class="feature-title">mining</h3>
                    <p class="feature-desc">mine ores, sell them, and manage mining claims for passive income.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-store"></i></div>
                    <h3 class="feature-title">shop & trading</h3>
                    <p class="feature-desc">buy items, trade with others, bazaar marketplace, commodity market.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-trophy"></i></div>
                    <h3 class="feature-title">leaderboards</h3>
                    <p class="feature-desc">server and global rankings for balance, xp, fish, gambling, and more.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-chart-line"></i></div>
                    <h3 class="feature-title">leveling</h3>
                    <p class="feature-desc">xp system, level roles, rank cards, xp blacklists, configurable per server.
                    </p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-tools"></i></div>
                    <h3 class="feature-title">utilities</h3>
                    <p class="feature-desc">user info, server info, avatars, banners, polls, reaction roles, giveaways,
                        snipe.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                    <h3 class="feature-title">moderation</h3>
                    <p class="feature-desc">anti-spam, url guard, text filter, reaction filter, autopurge.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-gamepad"></i></div>
                    <h3 class="feature-title">games</h3>
                    <p class="feature-desc">heists, boss raids, tic-tac-toe, reaction games, black tea.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-heart"></i></div>
                    <h3 class="feature-title">social</h3>
                    <p class="feature-desc">hug, kiss, pat commands with gifs.</p>
                </div>

                <div class="feature-card">
                    <i class="fas fa-chevron-down feature-card-indicator"></i>
                    <div class="feature-icon"><i class="fas fa-bolt"></i></div>
                    <h3 class="feature-title">performance</h3>
                    <p class="feature-desc">written in C++. fast responses, stable.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Commands Section -->
