                            <div class="command-desc">deposit money into your bank</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">bank withdraw</div>
                            <div class="command-aliases">w, with</div>
                            <div class="command-desc">withdraw money from your bank</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">bank upgrade</div>
                            <div class="command-desc">upgrade your bank limit</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">bank loan</div>
                            <div class="command-desc">take out or repay a bank loan</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">pay</div>
                            <div class="command-aliases">give</div>
                            <div class="command-desc">transfer money to another user</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">daily</div>
                            <div class="command-desc">claim your daily reward</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">weekly</div>
                            <div class="command-desc">claim your weekly reward</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">work</div>
                            <div class="command-desc">earn money by working</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">rob</div>
                            <div class="command-desc">attempt to rob another user</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">passive</div>
                            <div class="command-desc">toggle passive mode (can't rob or be robbed)</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">prestige</div>
                            <div class="command-desc">reset progress for a prestige rank</div>
                        </div>
                        <div class="command-item">
                            <div class="command-name">rebirth</div>
                            <div class="command-aliases">rb, transcend</div>
